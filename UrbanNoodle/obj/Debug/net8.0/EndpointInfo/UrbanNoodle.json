  "components": {
    "schemas": {
      "AccountDTO": {
        "required": [
          "fullName",
          "password",
          "phone",
          "role"
        ],
        "type": "object",
        "properties": {
          "password": {
            "minLength": 1,
            "type": "string"
          },
          "fullName": {
            "maxLength": 50,
            "minLength": 3,
            "pattern": "^[\\p{L}\\s]+$",
            "type": "string"
          },
          "phone": {
            "minLength": 1,
            "pattern": "^0\\d{9}$",
            "type": "string",
            "format": "tel"
          },
